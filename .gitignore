# build output
dist/
public/slides/
public/slide-images/

# temporary files (NILTO migration dumps, scratch)
tmp/

# Per-deck junctions/copies for slides (set up by `just setup-slides`).
# Negations re-include the SSoT under _shared/.
src/content/slides/*/components
src/content/slides/*/slide-images
src/content/slides/*/global-bottom.vue
src/content/slides/*/vite.config.ts
!src/content/slides/_shared/components
!src/content/slides/_shared/slide-images
!src/content/slides/_shared/global-bottom.vue
!src/content/slides/_shared/vite.config.ts

# Rehearsal simulation artifacts (just sim-video): generated audio / png / video
src/content/slides/*/_sim/

# CV (content-external/cv): 連絡先(PII)と生成PDFのみ除外。他のデータ・写真はコミットする
content-external/cv/data/contact.yaml
content-external/cv/out/

# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Yarn
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
