---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'about'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<article class="entry">
  <a href="/about" class="back-link">← About に戻る</a>

  <header class="entry-header">
    <span class="date">{entry.data.date}</span>
    <h1>{entry.data.title}</h1>
    {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
  </header>

  <div class="entry-body">
    <Content />
  </div>
</article>

<style>
  .entry {
    max-width: 760px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: #6366f1;
    text-decoration: none;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .entry-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .date {
    font-size: 0.85rem;
    color: #6b7280;
    font-variant-numeric: tabular-nums;
  }

  h1 {
    font-size: 2rem;
    margin: 0.5rem 0 0.75rem;
    line-height: 1.3;
  }

  .summary {
    margin: 0;
    color: #4b5563;
    font-size: 1rem;
    line-height: 1.6;
  }

  .entry-body {
    line-height: 1.8;
    color: #1a1a1a;
  }

  .entry-body :global(h2) {
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.25rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .entry-body :global(h3) {
    font-size: 1.2rem;
    margin: 2rem 0 0.75rem;
  }

  .entry-body :global(h2),
  .entry-body :global(h3),
  .entry-body :global(h4),
  .entry-body :global(h5),
  .entry-body :global(h6) {
    position: relative;
  }

  .entry-body :global(.heading-anchor) {
    margin-left: 0.4em;
    color: #9ca3af;
    text-decoration: none;
    font-weight: normal;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .entry-body :global(h2:hover .heading-anchor),
  .entry-body :global(h3:hover .heading-anchor),
  .entry-body :global(h4:hover .heading-anchor),
  .entry-body :global(h5:hover .heading-anchor),
  .entry-body :global(h6:hover .heading-anchor),
  .entry-body :global(.heading-anchor:focus) {
    opacity: 1;
  }

  .entry-body :global(.heading-anchor:hover) {
    color: #6366f1;
    text-decoration: none;
  }

  .entry-body :global(p) {
    margin: 1rem 0;
  }

  .entry-body :global(ul),
  .entry-body :global(ol) {
    padding-left: 1.5rem;
  }

  .entry-body :global(li) {
    margin: 0.4rem 0;
  }

  .entry-body :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid #6366f1;
    background: rgba(99, 102, 241, 0.05);
    color: #374151;
    border-radius: 0 8px 8px 0;
  }

  .entry-body :global(blockquote p) {
    margin: 0.5rem 0;
  }

  .entry-body :global(a) {
    color: #6366f1;
  }

  .entry-body :global(code) {
    background: #f3f4f6;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .entry-body :global(hr) {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .entry-body :global(table) {
    border-collapse: collapse;
    margin: 1.25rem 0;
    width: 100%;
    font-size: 0.95rem;
  }

  .entry-body :global(th),
  .entry-body :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    text-align: left;
  }

  .entry-body :global(th) {
    background: #f9fafb;
    font-weight: 600;
  }

  :global(html[data-theme='dark']) .back-link {
    color: #818cf8;
  }

  :global(html[data-theme='dark']) .entry-header {
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme='dark']) .date {
    color: #9ca3af;
  }

  :global(html[data-theme='dark']) h1 {
    color: #fff;
  }

  :global(html[data-theme='dark']) .summary {
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .entry-body {
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .entry-body :global(h2) {
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme='dark']) .entry-body :global(h3) {
    color: #f3f4f6;
  }

  :global(html[data-theme='dark']) .entry-body :global(.heading-anchor) {
    color: #6b7280;
  }

  :global(html[data-theme='dark']) .entry-body :global(.heading-anchor:hover) {
    color: #818cf8;
  }

  :global(html[data-theme='dark']) .entry-body :global(blockquote) {
    background: rgba(129, 140, 248, 0.08);
    border-left-color: #818cf8;
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .entry-body :global(a) {
    color: #818cf8;
  }

  :global(html[data-theme='dark']) .entry-body :global(code) {
    background: #1f2937;
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .entry-body :global(hr) {
    border-top-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme='dark']) .entry-body :global(th),
  :global(html[data-theme='dark']) .entry-body :global(td) {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme='dark']) .entry-body :global(th) {
    background: #1f2937;
  }
</style>
