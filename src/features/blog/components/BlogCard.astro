---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const formattedDate = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<a href={`/blog/${post.id}`} class="blog-card">
  <div class="card-content">
    <div class="pub-date">{formattedDate}</div>
    <h3>{title}</h3>
    <p class="description">{description}</p>
    {
      tags && tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )
    }
  </div>
</a>

<style>
  .blog-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 12px;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    overflow: hidden;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .card-content {
    padding: 1.5rem;
  }

  .pub-date {
    font-size: 0.8rem;
    color: #6b7280;
    margin-bottom: 0.75rem;
  }

  h3 {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    color: #1a1a1a;
    line-height: 1.4;
  }

  .description {
    margin: 0 0 1rem;
    font-size: 0.9rem;
    color: #4b5563;
    line-height: 1.7;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    border-radius: 4px;
    color: #0369a1;
  }

  :global(html[data-theme='dark']) .blog-card {
    background: rgba(30, 30, 30, 0.9);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme='dark']) .pub-date {
    color: #9ca3af;
  }

  :global(html[data-theme='dark']) h3 {
    color: #fff;
  }

  :global(html[data-theme='dark']) .description {
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .tag {
    background: linear-gradient(135deg, #1e3a5f 0%, #1e3a5f 100%);
    color: #7dd3fc;
  }
</style>
