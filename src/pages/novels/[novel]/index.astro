---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { chapterSlugOf, chaptersOf } from '../../../features/novel/utils/chapters';
import { NOVEL_STATUS_LABELS, formatNovelDate } from '../../../features/novel/utils/novelStatus';

export async function getStaticPaths() {
  const novels = await getCollection('novels', ({ data }) => !data.draft);
  return novels.map((novel) => ({
    params: { novel: novel.data.slug },
    props: { novel },
  }));
}

const { novel } = Astro.props;
const { title, slug, status, synopsis, tags, created_at, updated_at, platforms } = novel.data;
const kakuyomuUrl = platforms?.kakuyomu?.url;

const chapters = chaptersOf(await getCollection('novel_chapters'), slug);
---

<Layout>
  <main>
    <div class="container">
      <a href="/novels" class="back-link">← 作品一覧に戻る</a>

      <article class="novel-detail">
        <header>
          <div class="meta-row">
            <span class:list={['status', status]}>{NOVEL_STATUS_LABELS[status]}</span>
            {
              tags && tags.length > 0 && (
                <div class="tags">
                  {tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )
            }
          </div>
          <h1>{title}</h1>
          <p class="synopsis">{synopsis}</p>
          <p class="dates">
            {formatNovelDate(created_at)} 開始 / {formatNovelDate(updated_at)} 更新
          </p>
          {
            kakuyomuUrl && (
              <a href={kakuyomuUrl} target="_blank" rel="noopener" class="platform-link">
                <span aria-hidden="true">📖</span> カクヨムで読む ↗
              </a>
            )
          }
        </header>

        <section class="section">
          <h2>目次</h2>
          <ol class="chapter-list">
            {
              chapters.map((chapter) => (
                <li>
                  <a href={`/novels/${slug}/${chapterSlugOf(chapter)}`} class="chapter-link">
                    {chapter.data.title}
                  </a>
                </li>
              ))
            }
          </ol>
        </section>
      </article>
    </div>
  </main>
</Layout>

<style>
  main {
    padding: 2rem;
    min-height: 100vh;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: #6366f1;
    text-decoration: none;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .novel-detail {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 16px;
    padding: 2rem;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
  }

  .meta-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .status {
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background: #f3f4f6;
    color: #374151;
  }

  .status.ongoing {
    background: #dcfce7;
    color: #15803d;
  }

  .status.completed {
    background: #e0e7ff;
    color: #4338ca;
  }

  .status.hiatus {
    background: #fef3c7;
    color: #92400e;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.8rem;
    padding: 0.25rem 0.625rem;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    border-radius: 6px;
    color: #0369a1;
  }

  h1 {
    font-size: 1.75rem;
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .synopsis {
    margin: 0 0 1rem;
    color: #4b5563;
    line-height: 1.8;
    white-space: pre-line;
  }

  .dates {
    margin: 0;
    font-size: 0.85rem;
    color: #6b7280;
  }

  .platform-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    padding: 0.45rem 0.9rem;
    background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
    border: 1px solid rgba(3, 105, 161, 0.2);
    border-radius: 8px;
    color: #0369a1;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.2s ease;
  }

  .platform-link:hover {
    background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
  }

  .section h2 {
    font-size: 1rem;
    color: #6b7280;
    margin: 0 0 0.75rem;
    font-weight: 500;
  }

  .chapter-list {
    margin: 0;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .chapter-list li::marker {
    color: #9ca3af;
    font-size: 0.9rem;
  }

  .chapter-link {
    color: #1f2937;
    text-decoration: none;
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .chapter-link:hover {
    color: #6366f1;
    text-decoration: underline;
  }

  :global(html[data-theme='dark']) .back-link {
    color: #818cf8;
  }

  :global(html[data-theme='dark']) .novel-detail {
    background: rgba(30, 30, 30, 0.9);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme='dark']) header {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html[data-theme='dark']) .status {
    background: #374151;
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .status.ongoing {
    background: #14532d;
    color: #86efac;
  }

  :global(html[data-theme='dark']) .status.completed {
    background: #312e81;
    color: #c7d2fe;
  }

  :global(html[data-theme='dark']) .status.hiatus {
    background: #422006;
    color: #fcd34d;
  }

  :global(html[data-theme='dark']) .tag {
    background: linear-gradient(135deg, #1e3a5f 0%, #1e3a5f 100%);
    color: #7dd3fc;
  }

  :global(html[data-theme='dark']) h1 {
    color: #fff;
  }

  :global(html[data-theme='dark']) .synopsis {
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .dates,
  :global(html[data-theme='dark']) .section h2 {
    color: #9ca3af;
  }

  :global(html[data-theme='dark']) .chapter-link {
    color: #e5e7eb;
  }

  :global(html[data-theme='dark']) .chapter-link:hover {
    color: #818cf8;
  }

  :global(html[data-theme='dark']) .platform-link {
    background: linear-gradient(135deg, #1e3a5f 0%, #1e3a5f 100%);
    border-color: rgba(125, 211, 252, 0.25);
    color: #7dd3fc;
  }

  :global(html[data-theme='dark']) .platform-link:hover {
    background: linear-gradient(135deg, #1e4a6f 0%, #1e4a6f 100%);
  }
</style>
